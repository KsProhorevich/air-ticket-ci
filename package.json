{
  "name": "air-ticket-ci",
  "version": "1.0.0",
  "description": "Air ticket cost calculation with Jest + Cucumber + Playwright + CI/CD",
  "main": "server.js",
  "scripts": {
    "test": "jest --config=jest.config.allure.js",
    "test:unit": "jest --config=jest.config.allure.js",
    "bdd": "cucumber-js --format summary --format html:report.html",
    "test:api": "cucumber-js",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:ui:report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui && npm run allure:generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:docker": "bash scripts/docker-entrypoint.sh"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@cucumber/cucumber": "^11.3.0",
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.34.1",
    "allure-cucumberjs": "^3.4.1",
    "allure-jest": "^3.4.1",
    "allure-playwright": "^3.4.1",
    "babel-jest": "^30.0.5",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "wait-on": "^8.0.5"
  }
}
